{
"failOn": ["error"],
"format": "stylish",
"rules": {
"no-latest-tag": "error",
"require-tagged-base-image": "error",
"copy-deps-before-source": "warning",
"prefer-copy-over-add": "warning",
"require-non-root-user": "warning",
"no-curl-bash": "error",
"require-explicit-cmd-or-entrypoint": "warning"
}
}