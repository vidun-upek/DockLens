{
  "name": "dockerfile-lint-plus",
  "version": "1.0.0",
  "description": "CLI linter for Dockerfiles focused on security, reproducibility, performance, and maintainability.",
  "type": "module",
  "bin": {
    "dockerfile-lint-plus": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --target node18 --clean",
    "test": "vitest run --pool forks",
    "lint:sample": "tsx src/cli.ts analyze examples/bad/Dockerfile",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "docker",
    "dockerfile",
    "linter",
    "devops",
    "security",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}